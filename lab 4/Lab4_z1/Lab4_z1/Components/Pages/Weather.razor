@page "/weather"
@rendermode InteractiveServer
@attribute [StreamRendering]

<PageTitle>Weather</PageTitle>

<h1>Weather</h1>
<p>This component demonstrates showing data.</p>

<div class="mb-3">
    <label class="form-label">Filtruj po Summary:</label>
    @* Zwróć uwagę na dodany znak = przy class *@
    <input class="form-control" @oninput="@Input" placeholder="Wpisz np. Freezing" />
</div>

@if (forecasts == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Temp. (C)</th>
                <th>Temp. (F)</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in filtredforecasts)
            {
                <tr>
                    <td>@forecast.Date.ToShortDateString()</td>
                    <td>@forecast.TemperatureC</td>
                    <td>@forecast.TemperatureF</td>
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>

    <p>Number of warm days: @warmDays</p>

	<button class="btn btn-primary" @onclick="WarmDaysFIlter">Pokaż liczbę ciepłych dni</button>
	<button class="btn btn-secondary" @onclick="Restore">Resetuj filtr</button>

}

@code {
    private WeatherForecast[]? forecasts;
    private WeatherForecast[]? filtredforecasts;
    private int warmDays = 0;

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(500);

        var startDate = DateOnly.FromDateTime(DateTime.Now);
        var summaries = new[] { "Freezing", "Bracing", "Chilly", "Cool", "Mild", "Warm", "Balmy", "Hot", "Sweltering", "Scorching" };
        forecasts = Enumerable.Range(1, 10).Select(index => new WeatherForecast
        {
            Date = startDate.AddDays(index),
            TemperatureC = Random.Shared.Next(-20, 55),
            Summary = summaries[Random.Shared.Next(summaries.Length)]
        }).ToArray();

        warmDays = forecasts.Count(f => f.TemperatureC > 15);
        filtredforecasts = forecasts;
    }

    private void WarmDaysFIlter()
    {
        if (forecasts != null)
        {
            filtredforecasts = forecasts.Where(f => f.TemperatureC > 15).ToArray();
        }
    }

    private void Restore()
    {
        filtredforecasts = forecasts;
    }

    private void Input(ChangeEventArgs arg)
    {
        if (forecasts !=null && arg.Value != null)
        {
			string searchString = arg.Value.ToString() ?? string.Empty;

			filtredforecasts = forecasts.Where(f => f.Summary != null && f.Summary.Contains(searchString, StringComparison.OrdinalIgnoreCase)).ToArray();
        }
    }


    private class WeatherForecast
    {
        public DateOnly Date { get; set; }
        public int TemperatureC { get; set; }
        public string? Summary { get; set; }
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);
    }
}
